{
  "manifest_version": 3,
  "name": "NeuroBridge AI Automation",
  "version": "1.0.0",
  "description": "Autonomous Qwen AI Controller via Supabase",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://aeopowovqksexgvseiyq.supabase.co/*",
    "https://chat.qwen.ai/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.qwen.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
